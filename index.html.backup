<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cocoa Market Intelligence — AI-Powered Magazine for Investors & Exporters</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="./styles.css" />

    <meta name="description" content="AI-driven cocoa market intelligence magazine for investors and exporters. Centralize global pricing, macro indicators, and EUDR compliance alerts." />
    <meta name="theme-color" content="#3D2B1F" />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="hero">
      <div class="hero-media" aria-hidden="true"></div>
      <div class="hero-grid" aria-hidden="true"></div>

      <div class="container hero-content">
        <div class="row g-4 align-items-center">
          <div class="col-12 col-lg-6">
            <div class="glass p-4 p-md-5">
              <p class="eyebrow">AI-Powered Cocoa Intelligence</p>
              <h1 class="display-5 display-md-4 hero-title">Protect Your Yield. Master the Market.</h1>
              <p class="lead hero-lead">
                The premier AI-driven news and intelligence magazine for cocoa investors and exporters. Centralizing global pricing, macroeconomic indicators, and EUDR compliance alerts.
              </p>

              <form id="heroWaitlist" class="waitlist-form mt-4" novalidate>
                <div class="d-flex flex-column flex-sm-row gap-2">
                  <input class="form-control form-control-lg" type="email" placeholder="Work Email" required />
                  <button class="btn btn-gold btn-lg" type="submit">Get Early Access & Market Briefs</button>
                </div>
                <div id="heroFormStatus" class="form-status mt-2"></div>
              </form>
            </div>
          </div>

          <div class="col-12 col-lg-6">
            <div class="glass p-4 p-md-5">
              <div class="live-indicator">LIVE</div>
              <h3 class="h4 mb-3">Terminal View</h3>

              <div class="ticker-grid">
                <div class="ticker-card">
                  <div class="ticker-label">Global Cocoa Price</div>
                  <div class="ticker-value">$9,850/MT</div>
                  <div class="ticker-delta ticker-up">▲ +2.4%</div>
                </div>
                <div class="ticker-card">
                  <div class="ticker-label">EUDR Rejection Risk</div>
                  <div class="ticker-value">12%</div>
                  <div class="ticker-delta ticker-elevated">Elevated this week</div>
                </div>
                <div class="ticker-card">
                  <div class="ticker-label">CSSV Heatmap Alerts</div>
                  <div class="ticker-value">3 Hotspots</div>
                  <div class="ticker-delta">West Central</div>
                </div>
              </div>

              <div class="mt-3 small text-cream-80">
                Data refreshed every 5 minutes. AI-driven risk models.
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main id="main">
      <section class="section section-cream" id="latest">
        <div class="container">
          <div class="row g-3 align-items-end">
            <div class="col-12 col-lg-7">
              <h2 class="section-title">Latest Intelligence</h2>
              <p class="section-lead">
                Actionable insights you won't find anywhere else—tailored for investors, exporters, and remote farm owners.
              </p>
            </div>
            <div class="col-12 col-lg-5">
              <div class="note">
                <div class="note__title">Why it matters</div>
                <div class="note__body">Fragmented field data and opaque pricing leave billions on the table. We centralize the signal.</div>
              </div>
            </div>
          </div>

          <div class="row g-3 mt-2">
            <div class="col-12 col-md-6 col-lg-4">
              <article class="intelligence-card glass glass--light">
                <div class="intelligence-card__img" style="background-image: url('https://images.unsplash.com/photo-1605000797499-95a51c5269ad?auto=format&fit=crop&w=900&q=80');" aria-label="Article thumbnail"></div>
                <div class="intelligence-card__body p-4">
                  <span class="pill pill--dark">Compliance</span>
                  <h3 class="intelligence-card__title mt-2">Navigating EUDR: How to avoid 20% lot downgrade in European markets.</h3>
                  <p class="intelligence-card__meta">5 min read • 2 days ago</p>
                </div>
              </article>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
              <article class="intelligence-card glass glass--light">
                <div class="intelligence-card__img" style="background-image: url('https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=900&q=80');" aria-label="Article thumbnail"></div>
                <div class="intelligence-card__body p-4">
                  <span class="pill pill--dark">Markets</span>
                  <h3 class="intelligence-card__title mt-2">The Power Game: Predicting price controls in Ghana and Côte d'Ivoire for Q3.</h3>
                  <p class="intelligence-card__meta">7 min read • 4 days ago</p>
                </div>
              </article>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
              <article class="intelligence-card glass glass--light">
                <div class="intelligence-card__img" style="background-image: url('https://images.unsplash.com/photo-1586953208448-b95a79798f07?auto=format&fit=crop&w=900&q=80');" aria-label="Article thumbnail"></div>
                <div class="intelligence-card__body p-4">
                  <span class="pill pill--dark">Risk Modeling</span>
                  <h3 class="intelligence-card__title mt-2">CSSV Predictive Modeling: Where the next outbreak is likely to hit.</h3>
                  <p class="intelligence-card__meta">6 min read • 1 week ago</p>
                </div>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section section-slate" id="value">
        <div class="container">
          <div class="row g-4 align-items-center">
            <div class="col-12 col-lg-6">
              <h2 class="section-title text-cream">Why Join Beta?</h2>
              <p class="section-lead text-cream-80">
                Stop relying on fragmented field data. We bring macroeconomic realities, disease-risk monitoring, and strict export compliance mandates directly to your screen and inbox.
              </p>
              <div class="mt-4">
                <div class="value-point">
                  <div class="value-point__icon">⚡</div>
                  <div class="value-point__body">
                    <div class="value-point__title">Real-time pricing & risk</div>
                    <div class="value-point__text">Live cocoa prices, EUDR alerts, and CSSV heatmaps refreshed continuously.</div>
                  </div>
                </div>
                <div class="value-point">
                  <div class="value-point__icon">📈</div>
                  <div class="value-point__body">
                    <div class="value-point__title">Predictive analytics</div>
                    <div class="value-point__text">AI-driven forecasts for price moves, policy shifts, and outbreak risk.</div>
                  </div>
                </div>
                <div class="value-point">
                  <div class="value-point__icon">📬</div>
                  <div class="value-point__body">
                    <div class="value-point__title">Weekly intelligence briefs</div>
                    <div class="value-point__text">Curated insights delivered to your inbox—no noise, only signal.</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-6" id="waitlist">
              <div class="glass p-4 p-md-5">
                <p class="eyebrow">Secure Your Spot</p>
                <h3 class="h4 mb-3">Join the elite network of remote owners and exporters.</h3>
                <form id="bottomWaitlist" class="waitlist-form" novalidate>
                  <div class="row g-3">
                    <div class="col-12">
                      <label class="form-label" for="bottomEmail">Work Email</label>
                      <input class="form-control" id="bottomEmail" name="email" type="email" autocomplete="email" required />
                      <div class="invalid-feedback">Please enter a valid email.</div>
                    </div>
                    <div class="col-12">
                      <label class="form-label" for="bottomRole">Role (optional)</label>
                      <select class="form-select" id="bottomRole" name="role">
                        <option value="">Select one…</option>
                        <option>Remote Farm Owner</option>
                        <option>Investor</option>
                        <option>Exporter</option>
                        <option>Analyst</option>
                      </select>
                    </div>
                    <div class="col-12 d-grid">
                      <button class="btn btn-gold btn-lg" type="submit">Join Waitlist</button>
                    </div>
                    <div class="col-12">
                      <div id="bottomFormStatus" class="form-status mt-2" role="status" aria-live="polite"></div>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <div class="row g-3 align-items-center">
          <div class="col-12 col-lg-7">
            <div class="footer-brand d-flex align-items-center gap-2">
              <span class="brand-mark brand-mark--sm" aria-hidden="true"></span>
              <div>
                <div class="footer-title">Cocoa Market Intelligence</div>
                <div class="footer-subtitle">AI-powered magazine for investors & exporters</div>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-5">
            <div class="footer-links">
              <a href="#latest">Latest</a>
              <a href="#value">Value</a>
              <a href="#waitlist">Waitlist</a>
            </div>
          </div>
        </div>

        <div class="footer-rule"></div>
        <div class="d-flex flex-column flex-md-row justify-content-between gap-2 small text-cream-70">
          <div>© <span id="year"></span> Cocoa Market Intelligence. All rights reserved.</div>
          <div>Built for Ghana, Côte d'Ivoire, and global cocoa leaders.</div>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="./script.js"></script>
  </body>
</html>